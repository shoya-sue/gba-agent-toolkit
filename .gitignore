# =============================================================
#  ROM / セーブデータ ― 絶対にコミットしない
#  （自己所有カートリッジから吸い出したもののみ使用・配布禁止）
# =============================================================
*.gba
*.gb
*.gbc
*.agb
*.bin
# セーブ / セーブステート
*.sav
*.srm
*.rtc
*.state
*.savestate
*.ss[0-9]
roms/
saves/
states/
bios/
# プレイスルーハーネスの実行記録（ログ・スクショ・スナップショット）
runs/
# ゲーム固有 state-map（実アドレス・ROM タイトルを含み得るため別管理）。
# 一般化テンプレート example.json のみコミットする。
agent/state-maps/*.local.json
# メモリスキャンの中間スナップショット
*.snapshot.json

# --- OS ---
.DS_Store
Thumbs.db

# --- Node (mcp-server / launcher frontend) ---
node_modules/
dist/
build/
*.log
npm-debug.log*
yarn-error.log*
.npm

# --- Rust / Tauri (launcher) ---
target/
launcher/src-tauri/target/
launcher/src-tauri/gen/
# tauri icon が生成するモバイル/Store 用（macOS launcher では不使用）
launcher/src-tauri/icons/android/
launcher/src-tauri/icons/ios/
launcher/src-tauri/icons/Square*.png
launcher/src-tauri/icons/StoreLogo.png
launcher/src-tauri/icons/64x64.png

# --- Python (PyBoy 経路 / mcp) ---
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/

# --- 環境変数 / シークレット ---
.env
.env.local
.env.*.local

# --- エディタ ---
.idea/
.vscode/
*.swp
